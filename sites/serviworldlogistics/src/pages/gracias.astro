---
import Layout from '../layouts/Layout.astro';
import siteConfig from '../../config/site.config.ts';
---

<Layout
  title={`Gracias — ${siteConfig.site.name}`}
  description="Hemos recibido su mensaje. Nuestro equipo le contactará pronto."
  noindex={true}
>
  <main class="font-body pt-32 pb-24 md:pt-40 md:pb-32 min-h-[70vh]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <div
        class="w-20 h-20 md:w-24 md:h-24 mx-auto mb-10 rounded-full bg-emerald-500/15 ring-2 ring-emerald-600/25 flex items-center justify-center"
        aria-hidden="true"
      >
        <i class="fa-solid fa-circle-check text-4xl md:text-5xl text-emerald-600"></i>
      </div>
      <span
        class="inline-block px-4 py-2 bg-primary/10 text-primary text-xs font-black uppercase tracking-widest mb-6"
      >
        Cotización
      </span>
      <h1 class="text-4xl md:text-5xl font-display font-black text-slate-900 mb-6 leading-tight">
        Mensaje <span class="text-primary">recibido</span>
      </h1>
      <p class="text-lg text-slate-600 leading-relaxed mb-10 max-w-xl mx-auto">
        Gracias por contactarnos. Hemos recibido su solicitud y nuestro equipo le responderá a la brevedad,
        habitualmente en menos de 24 horas hábiles.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-stretch sm:items-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-primary text-white px-10 py-4 font-black uppercase tracking-widest text-xs hover:bg-accent transition-all shadow-lg"
        >
          <i class="fa-solid fa-house"></i>
          Volver al inicio
        </a>
        <a
          href="/contacto/"
          class="inline-flex items-center justify-center gap-2 border-2 border-primary text-primary px-10 py-4 font-black uppercase tracking-widest text-xs hover:bg-primary hover:text-white transition-all"
        >
          <i class="fa-solid fa-paper-plane"></i>
          Enviar otra consulta
        </a>
      </div>
    </div>
  </main>
</Layout>
